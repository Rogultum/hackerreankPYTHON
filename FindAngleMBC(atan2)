import math

ab = int(input())
bc = int(input())

radian = math.atan2(ab, bc)  # find the angle in radian
degree = math.degrees(radian)  # converted to degree
degree_round = round(degree)
degree_sign = chr(176)

print(f"{degree_round}{degree_sign}")

